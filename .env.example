# INKEY List Admin Dashboard Environment Variables

# Main store connection
NEXT_PUBLIC_MAIN_STORE_URL=https://inkey-list-clone.netlify.app

# Admin settings
NEXT_PUBLIC_ADMIN_NAME="INKEY List Admin"
NEXT_PUBLIC_ADMIN_VERSION="1.0.0"

# Store API configuration
NEXT_PUBLIC_STORE_API_KEY=demo-api-key
ADMIN_TOKEN=demo-admin-token

# Optional: Analytics and monitoring
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Optional: External services
NEXT_PUBLIC_UPLOAD_CARE_PUBLIC_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
